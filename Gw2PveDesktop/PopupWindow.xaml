<Window x:Class="Gw2PveDesktop.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Gw2PveDesktop.Converters"
        Title="GW2 PvE — Fractals &amp; Bounties"
        SizeToContent="WidthAndHeight"
        MinHeight="320" MinWidth="400"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="False">
    <Window.Resources>
        <converters:PathToImageSourceConverter x:Key="PathToImageSource"/>
    </Window.Resources>
    <Border BorderBrush="#ccc" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar: drag region + close button -->
        <Border Grid.Row="0" Background="#f0f0f0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Cursor="SizeAll">
            <Grid Height="28">
                <TextBlock Text="GW2 PvE — Fractals &amp; Bounties" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"/>
                <Button x:Name="CloseButton" Content="✕" HorizontalAlignment="Right" Width="46" Height="28"
                        Background="Transparent" BorderThickness="0" FontSize="12" Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

    <Grid Grid.Row="1" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Reset countdown -->
        <TextBlock x:Name="ResetCountdownText" Grid.Row="0" HorizontalAlignment="Center" FontSize="12" Foreground="#555" Margin="0,0,0,8"/>

        <!-- Fractals header -->
        <TextBlock Grid.Row="1" Text="Fractals" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Today" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ItemsControl x:Name="FractalsTodayList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <ItemsControl ItemsSource="{Binding Instabilities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="12,0,0,2">
                                                <Image Width="20" Height="20" Margin="0,0,4,0" VerticalAlignment="Center"
                                                       Source="{Binding ImagePath, Converter={StaticResource PathToImageSource}}"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="Tomorrow" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ItemsControl x:Name="FractalsTomorrowList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <ItemsControl ItemsSource="{Binding Instabilities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="12,0,0,2">
                                                <Image Width="20" Height="20" Margin="0,0,4,0" VerticalAlignment="Center"
                                                       Source="{Binding ImagePath, Converter={StaticResource PathToImageSource}}"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- Raid Bounties header -->
        <TextBlock Grid.Row="3" Text="Raid Bounties" FontWeight="Bold" FontSize="14" Margin="0,12,0,6"/>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Today" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ItemsControl x:Name="BountiesTodayList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Image Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Source="{Binding ImagePath, Converter={StaticResource PathToImageSource}}"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="Tomorrow" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ItemsControl x:Name="BountiesTomorrowList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Image Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Source="{Binding ImagePath, Converter={StaticResource PathToImageSource}}"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </Grid>
    </Grid>
    </Border>
</Window>
