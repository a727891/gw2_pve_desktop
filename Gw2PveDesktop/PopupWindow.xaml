<Window x:Class="Gw2PveDesktop.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Gw2PveDesktop.Converters"
        Title="GW2 PvE — Fractals &amp; Bounties"
        SizeToContent="WidthAndHeight"
        MinHeight="320" MinWidth="400"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <converters:PathToImageSourceConverter x:Key="PathToImageSource"/>
        <!-- Menomonia (GW2-style) from Blish HUD / community; fallback Consolas -->
        <FontFamily x:Key="GuildWarsFont">pack://application:,,,/Gw2PveDesktop;component/Assets/menomonia.ttf#Menomonia, Consolas</FontFamily>
        <!-- GW2-style palette: cream/gold on dark wispy background -->
        <SolidColorBrush x:Key="GuildWarsTitleBrush" Color="#E8DCC8"/>
        <SolidColorBrush x:Key="GuildWarsHeaderBrush" Color="#D4C4A0"/>
        <SolidColorBrush x:Key="GuildWarsBodyBrush" Color="#C9B896"/>
        <SolidColorBrush x:Key="GuildWarsMutedBrush" Color="#A09078"/>
        <!-- Header bar: distinct strip like Blish StandardWindow title bar (semi-transparent dark + bottom separator) -->
        <SolidColorBrush x:Key="GuildWarsHeaderBarBackground" Color="#E01c1c20"/>
        <SolidColorBrush x:Key="GuildWarsHeaderBarBorderBrush" Color="#50C9B896"/>
    </Window.Resources>
    <Border x:Name="RootBorder" BorderThickness="0" TextElement.FontFamily="{StaticResource GuildWarsFont}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar: distinct header strip (Blish StandardWindow-style) -->
        <Border Grid.Row="0" Background="{StaticResource GuildWarsHeaderBarBackground}"
                BorderBrush="{StaticResource GuildWarsHeaderBarBorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Cursor="SizeAll">
            <Grid Height="32">
                <TextBlock Text="GW2 PvE — Fractals &amp; Bounties" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"
                           Foreground="{StaticResource GuildWarsTitleBrush}"/>
                <Button x:Name="CloseButton" Content="✕" HorizontalAlignment="Right" Width="46" Height="28"
                        Background="Transparent" BorderThickness="0" FontSize="12" Cursor="Hand"
                        Foreground="{StaticResource GuildWarsTitleBrush}"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

    <Grid Grid.Row="1" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Raid Bounties header -->
        <TextBlock Grid.Row="0" Text="Raid Bounties" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"
                   Foreground="{StaticResource GuildWarsHeaderBrush}"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="0"/>
                <ColumnDefinition Width="*" MinWidth="0"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Today" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{StaticResource GuildWarsBodyBrush}"/>
                <ItemsControl x:Name="BountiesTodayList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Image Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Source="{Binding ImagePath, Converter={StaticResource PathToImageSource}}"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{StaticResource GuildWarsBodyBrush}"
                                           MaxWidth="160" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="Tomorrow" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{StaticResource GuildWarsBodyBrush}"/>
                <ItemsControl x:Name="BountiesTomorrowList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Image Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Source="{Binding ImagePath, Converter={StaticResource PathToImageSource}}"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{StaticResource GuildWarsBodyBrush}"
                                           MaxWidth="160" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- Fractals header -->
        <TextBlock Grid.Row="2" Text="Fractals" FontWeight="Bold" FontSize="14" Margin="0,12,0,6"
                   Foreground="{StaticResource GuildWarsHeaderBrush}"/>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="0"/>
                <ColumnDefinition Width="*" MinWidth="0"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Today" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{StaticResource GuildWarsBodyBrush}"/>
                <ItemsControl x:Name="FractalsTodayList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource GuildWarsBodyBrush}"
                                           MaxWidth="160" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                <ItemsControl ItemsSource="{Binding Instabilities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="12,0,0,2">
                                                <Image Width="20" Height="20" Margin="0,0,4,0" VerticalAlignment="Center"
                                                       Source="{Binding ImagePath, Converter={StaticResource PathToImageSource}}"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{StaticResource GuildWarsMutedBrush}" VerticalAlignment="Center"
                                                           MaxWidth="140" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="Tomorrow" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{StaticResource GuildWarsBodyBrush}"/>
                <ItemsControl x:Name="FractalsTomorrowList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource GuildWarsBodyBrush}"
                                           MaxWidth="160" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                <ItemsControl ItemsSource="{Binding Instabilities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="12,0,0,2">
                                                <Image Width="20" Height="20" Margin="0,0,4,0" VerticalAlignment="Center"
                                                       Source="{Binding ImagePath, Converter={StaticResource PathToImageSource}}"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{StaticResource GuildWarsMutedBrush}" VerticalAlignment="Center"
                                                           MaxWidth="140" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- Reset countdown -->
        <TextBlock x:Name="ResetCountdownText" Grid.Row="4" HorizontalAlignment="Center" FontSize="12"
                   Foreground="{StaticResource GuildWarsMutedBrush}" Margin="0,12,0,0"/>
    </Grid>
    </Grid>
    </Border>
</Window>
