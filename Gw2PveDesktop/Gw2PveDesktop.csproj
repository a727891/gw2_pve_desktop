<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <!-- Single-file with embedded assets; requires .NET 8 Desktop Runtime on target machine -->
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <!-- No debug symbols in Release (smaller dist) -->
    <DebugType Condition="'$(Configuration)'=='Release'">none</DebugType>
    <!-- Exe icon (generated from Assets\1128644.png by PngToIco target) -->
    <ApplicationIcon>Assets\1128644.ico</ApplicationIcon>
  </PropertyGroup>


  <ItemGroup>
    <Content Include="Assets\1128644.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <EmbeddedResource Include="Assets\1128644.png" />
  </ItemGroup>

</Project>
